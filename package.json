    "jest": "^30.3.0",
    "shx": "^0.4.0"
  },
  "overrides": {
    "undici": "^7.24.0",
    "underscore": "^1.13.8",
    "qs": "^6.14.2",
    "path-to-regexp": "^8.4.2",
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.4",
    "dompurify": "^3.4.0"
  }
}
